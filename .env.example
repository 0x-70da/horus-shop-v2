# Backend API base URL (required)
# In development, use your local backend server
# In production, use your deployed backend URL
VITE_API_BASE_URL=http://localhost:5000/api

# Stripe publishable key (required, starts with pk_)
# Get this from your Stripe dashboard: https://dashboard.stripe.com/apikeys
# Never use a secret key (sk_) here - publishable keys only
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
